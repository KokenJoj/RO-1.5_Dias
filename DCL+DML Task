-- Business reason: Billing costs for Cardiology patients were adjusted due to increased equipment and maintenance expenses.
select b.bill_id, b.total_amount, d.name from billing b join treatment t on b.treatment_id = t.treatment_id join room_assignment ra on b.patient_id = ra.patient_id join room r on ra.room_id = r.room_id join department d on r.department_id = d.department_id where d.name = 'Cardiology';
update billing b
set total_amount = round(b.total_amount * 1.10, 2)
from room_assignment ra
join room r on ra.room_id = r.room_id
join department d on r.department_id = d.department_id
where b.patient_id = ra.patient_id 
and d.name = 'Cardiology';

